generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Profile {
  id              String   @id @default(cuid())
  name            String   @default("Tu Nombre")
  title           String   @default("Desarrollador Full Stack")
  photo           String?
  bio             String?  @default("Apasionado por la tecnología y el desarrollo de software.")
  email           String?  @default("tu@email.com")
  phone           String?  @default("+1 234 567 890")
  location        String?  @default("Ciudad, País")
  website         String?
  primaryColor    String   @default("#3b82f6")
  secondaryColor  String   @default("#1e40af")
  accentColor     String   @default("#f59e0b")
  backgroundColor String   @default("#ffffff")
  textColor       String   @default("#1f2937")
  theme           String   @default("default")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  socialLinks     SocialLink[]
  projects        Project[]
  certificates    Certificate[]
  experiences     Experience[]
  skills          Skill[]
}

model SocialLink {
  id        String   @id @default(cuid())
  platform  String
  url       String
  icon      String
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id           String   @id @default(cuid())
  title        String
  description  String?
  url          String?
  technologies String?
  images       String?
  startDate    String?
  endDate      String?
  featured     Boolean  @default(false)
  order        Int      @default(0)
  profileId    String
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Certificate {
  id          String   @id @default(cuid())
  title       String
  institution String?
  issueDate   String?
  fileData    String?
  fileType    String?
  description String?
  order       Int      @default(0)
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Experience {
  id          String   @id @default(cuid())
  title       String
  company     String
  location    String?
  startDate   String
  endDate     String?
  description String?
  type        String   @default("work")
  order       Int      @default(0)
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Skill {
  id       String   @id @default(cuid())
  name     String
  level    Int      @default(80)
  icon     String?
  category String   @default("General")
  order    Int      @default(0)
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
